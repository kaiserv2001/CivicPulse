@inherits LayoutComponentBase
@inject AuthState Auth
@inject IJSRuntime JS
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@implements IAsyncDisposable

<div class="page">
    <NavMenu />
    <main class="main-content">
        <div class="container py-4">
            @Body
        </div>
    </main>
    <footer class="text-center small text-muted py-3 border-top">
        <span class="me-1">Portfolio demo — live data from public APIs; accounts &amp; favorites are sample-only and reset when the demo sleeps (after ~15 min idle) or restarts.</span>
        @if (Env.IsDevelopment())
        {
            <span>·
                <a href="/swagger" target="_blank" rel="noopener">API docs</a>
            </span>
        }
        <span>·
            <a href="https://github.com/kaiserv2001/CivicPulse" target="_blank" rel="noopener">Source on GitHub</a>
        </span>
    </footer>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await Auth.TryRestoreAsync(JS);
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
