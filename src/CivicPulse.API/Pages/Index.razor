@page "/"
@inject AuthState Auth
@implements IDisposable

<PageTitle>CivicPulse — Find Your Ideal Outdoors</PageTitle>

<div class="hero text-center py-5">
    <h1 class="display-5 fw-bold mb-2">Find Your Ideal Outdoors</h1>
    <p class="lead text-muted mb-4">Real-time weather, air quality, and outdoor activity scores for any city.</p>
    <div class="search-container mx-auto" style="max-width:560px">
        <CitySearchBox />
    </div>
    <p class="text-muted mt-3 mb-0">
        <small>⚡ Free demo — first load may take ~30–50s if it's been idle, and demo accounts reset after ~15 min of inactivity.</small>
    </p>
    @if (!Auth.IsAuthenticated)
    {
        <p class="text-muted mt-3">
            <small><a href="/login?register=true">Register</a> or <a href="/login">sign in</a> to save favorites and compare cities.</small>
        </p>
    }
</div>

<div class="how-it-works container">
    <div class="row text-center g-4">
        <div class="col-md-4">
            <div class="step-card h-100">
                <div class="step-icon">🔍</div>
                <h3 class="h6 fw-bold mb-1">Search a city</h3>
                <p class="text-muted small mb-0">Type any city to pull its live conditions from across the globe.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="step-card h-100">
                <div class="step-icon">🌤️</div>
                <h3 class="h6 fw-bold mb-1">See live conditions</h3>
                <p class="text-muted small mb-0">Real-time weather and air quality, updated as you look.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="step-card h-100">
                <div class="step-icon">🏃</div>
                <h3 class="h6 fw-bold mb-1">Get activity scores</h3>
                <p class="text-muted small mb-0">A clear A–F grade for how good the day is to head outdoors.</p>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized() => Auth.OnChange += StateHasChanged;
    public void Dispose() => Auth.OnChange -= StateHasChanged;
}
